# ============================================================================
# RepoRover Phase 1.0 — environment configuration
# Copy to `.env` and fill in. Never commit the real .env.
# ============================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
# Add your ngrok host so webhook POSTs pass host validation, e.g.:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://abc-123.ngrok-free.app

# --- PostgreSQL (durable metadata; PRD §4) ---
POSTGRES_DB=reporover
POSTGRES_USER=reporover
POSTGRES_PASSWORD=reporover
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional explicit DSN reused by the LangGraph checkpointer (defaults derived
# from the POSTGRES_* values above):
# POSTGRES_DSN=postgresql://reporover:reporover@localhost:5432/reporover

# --- Celery / Redis broker (PRD §2, §5.1) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LangGraph checkpointer ---
# postgres = durable cross-invocation resume (writes graph state, incl. source,
#            to Postgres). memory = ephemeral, honors zero-source-retention but
#            does not survive a worker restart. (See note in src/graph.py.)
CHECKPOINTER=postgres

# --- BYOK encryption (PRD §3.1) ---
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- GitHub App (PRD §3.3, §3.4) ---
GITHUB_APP_ID=
# Paste the PEM contents (with literal newlines) or load from a file in deploy.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Local smoke test only (src/main.py); not used by the SaaS pipeline ---
# GITHUB_TOKEN=ghp_...
# GOOGLE_API_KEY=...
# E2B_API_KEY=...
